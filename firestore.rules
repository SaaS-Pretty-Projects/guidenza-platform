rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ---------- subscriptions ----------
    match /subscriptions/{subscriptionId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ---------- courses ----------
    match /courses/{courseId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
        && (resource.data.instructorId == request.auth.uid || isAdmin());

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      }
      match /announcements/{announcementId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn()
          && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid;
      }
    }

    // ---------- users ----------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin())
        && (!('credits' in request.resource.data) || request.resource.data.credits >= 0)
        && (isAdmin() || !('credits' in request.resource.data) || request.resource.data.credits <= resource.data.credits);
      allow delete: if false;

      // transactions are append-only by the owner
      match /transactions/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // ---------- coupons ----------
    match /coupons/{code} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ---------- earnings / withdrawals ----------
    match /earnings/{docId} {
      allow read: if isSignedIn()
        && (resource.data.instructorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.instructorId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /withdrawals/{docId} {
      allow read: if isSignedIn()
        && (resource.data.instructorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.instructorId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ---------- admins sentinel ----------
    match /admins/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    // ---------- default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
